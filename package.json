{
  "name": "superdnax-supersim-backend",
  "version": "1.0.0-beta.1",
  "description": "Backend for SuperSIM",
  "author": "Mike Festa",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mikefesta/supersim-backend.git"
  },
  "main": "index.js",
  "type": "module",
  "imports": {
    "#root/*.js": [
      "./src/*",
      "./dist/*.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch ./app/server.ts",
    "lint": "eslint . --ext .ts",
    "prettier-format": "prettier --config .prettierrc './app/**/*.ts' --write",
    "start": "node ./build/server.js"
  },
  "dependencies": {
    "@sequelize/core": "^7.0.0-alpha.48",
    "@sequelize/postgres": "^7.0.0-alpha.48",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "uuid": "^14.0.0",
    "uuidv7": "^1.2.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.4",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "sequelize-typescript": "^2.1.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "overrides": {
    "uuid": "$uuid"
  },
  "engines": {
    "node": "^24.14.0",
    "npm": "^11.11.0"
  }
}
